import self as l2
import fizz_protocol.memory
import list

local fn ev(id: Int, uid: Int, content: String) -> memory.MemoryEvent = {
  let empty_tags: List[String] = []
  memory.MemoryEvent {
    id: id, user_id: uid, session_id: none, role: memory.User,
    content: content, ts: id, tags: empty_tags,
  }
}

local fn content_of(o: Option[memory.MemoryEvent]) -> String =
  match o { some(e) => e.content, none => "<none>" }

test "query filters by user and keeps the last N (oldest-first)" {
  let all = [ev(1, 1, "a"), ev(2, 2, "x"), ev(3, 1, "b"), ev(4, 1, "c")]
  let got = l2.query(all, 1, 2)
  assert_eq(list.len(got), 2)
  assert_eq(content_of(list.first(got)), "b")
  assert_eq(content_of(list.last(got)), "c")
}

test "query with limit<=0 returns all matches" {
  let all = [ev(1, 1, "a"), ev(2, 1, "b"), ev(3, 9, "x")]
  assert_eq(list.len(l2.query(all, 1, 0)), 2)
  assert_eq(list.len(l2.query(all, 9, -5)), 1)
}

test "query of unknown user is empty" {
  let all = [ev(1, 1, "a")]
  assert_eq(list.len(l2.query(all, 42, 10)), 0)
}

test "next_id is max id + 1; 1 on empty" {
  let empty: List[memory.MemoryEvent] = []
  assert_eq(l2.next_id(empty), 1)
  assert_eq(l2.next_id([ev(3, 1, "a"), ev(7, 1, "b"), ev(2, 1, "c")]), 8)
}

test "line round-trips through encode/parse" {
  let line = l2.event_to_line(ev(5, 1, "ねこ"))
  assert_eq(content_of(l2.parse_line(line)), "ねこ")
  assert_eq(l2.parse_line("not json"), none)
}
